# ── Database ──────────────────────────────────────────────────────────────────
# MySQL / TiDB connection string
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://homevault:password@localhost:3306/homevault

# ── Auth (Manus OAuth) ────────────────────────────────────────────────────────
# These are set automatically on the Manus platform.
# For self-hosted deployments, configure your own OAuth server or leave blank
# and the app will show a setup instructions screen.
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Client-side OAuth vars (must be prefixed VITE_ to be visible in the browser)
# These must match the server-side vars above
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ── Manus Forge (LLM / voice / maps / push notifications) ────────────────────
# Powers the optional AI features. Not used for file storage — that's
# Google Drive or S3, configured below.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── File Storage ──────────────────────────────────────────────────────────────
# Pick a backend with STORAGE_BACKEND: "local", "s3" or "gdrive". Leave empty
# for auto-detection (gdrive if Google env vars are set, else s3 if configured,
# else local). You can also switch backends live from Settings → File storage
# (no restart) — that choice is stored in the DB and overrides STORAGE_BACKEND.
STORAGE_BACKEND=local

# ── Option A: Local disk (easiest — no external accounts) ─────────────────────
# Files are stored on this server's own filesystem and streamed back through
# /api/files/<id>. Best for self-hosted Docker and the Home Assistant add-on.
# STORAGE_DIR MUST be a persistent, writable path:
#   - docker-compose: mount a named volume, e.g.
#       volumes: [ "homevault_uploads:/data/uploads" ]
#     and set STORAGE_DIR=/data/uploads
#   - Home Assistant add-on: use /data (the add-on's persistent dir), e.g.
#       STORAGE_DIR=/data/uploads
#     Anything outside /data is wiped on add-on update.
STORAGE_DIR=/data/uploads

# ── Option B: Google Drive ────────────────────────────────────────────────────
# Files are stored in the app-owner's own Google Drive under
# HomeVault/uploads/<userId>/. The browser never talks to Drive directly —
# the app server streams downloads via /api/files/<id>.
#
#   1. Create a project at https://console.cloud.google.com
#   2. Enable the Google Drive API
#   3. OAuth consent screen → External; add your own Google account as a Test User
#   4. Credentials → Create OAuth client → Web application
#      Authorized redirect URI: <APP_BASE_URL>/api/google-drive/callback
#   5. Copy the Client ID / Secret below
#   6. Start the server, log in as admin, visit /admin/google-drive and click
#      "Connect" — the refresh token is then stored in the app_settings DB table
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3005/api/google-drive/callback

# ── Admin setup token (REQUIRED when NO_AUTH=true) ────────────────────────────
# When NO_AUTH is on (Home Assistant add-on mode), every request is auto-
# admin-ed by the session middleware. To prevent a LAN attacker from binding
# the homeowner's Drive to their own Google account, the connect/callback/
# disconnect endpoints additionally require this token (as
#   ?setup_token=...     on /connect
#   X-Admin-Setup-Token  header on /disconnect).
# Pick a long random string and share it only with the homeowner during setup.
# Leave blank if NO_AUTH=false — it has no effect then.
ADMIN_SETUP_TOKEN=

# ── Option C: Any S3-compatible provider ──────────────────────────────────────
# Cloudflare R2 free tier: 10 GB storage, zero egress, 1M writes + 10M reads/mo
#   1. Sign up at dash.cloudflare.com → R2 → Create bucket "homevault"
#   2. Get Account ID from R2 overview
#   3. Create API token: R2 → Manage API Tokens → Create Token (Edit permissions)
# Downloads go through /api/files/<id>, which 302-redirects to a 5-minute
# presigned URL — STORAGE_PUBLIC_URL is no longer required.
# (These can also be pasted into Settings → File storage instead of .env.)
STORAGE_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_BUCKET=homevault
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# ── Maps (optional) ───────────────────────────────────────────────────────────
# Google Maps JavaScript API key — restrict to your domain in Google Cloud Console
# Without this, the map on the dashboard will show a placeholder
VITE_GOOGLE_MAPS_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
# PORT=3000

# ── Notifications (all optional; each channel is skipped until configured) ─────
# Public origin of this install — used to register the Telegram webhook and to
# build absolute links in emails, e.g. https://home.example.com
PUBLIC_BASE_URL=

# Email (SMTP). Channel is active when SMTP_HOST and a from/user are set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Telegram bot (two-way + outbound). Create a bot via @BotFather for the token.
# TELEGRAM_WEBHOOK_SECRET is an arbitrary string used to verify inbound webhooks.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Browser Web Push (VAPID). Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@homevault.local
